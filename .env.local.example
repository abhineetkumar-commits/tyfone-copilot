# Anthropic
ANTHROPIC_API_KEY=sk-ant-...
 
# Google Drive Service Account
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-sa@project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY\n-----END PRIVATE KEY-----\n"
GOOGLE_DRIVE_FOLDER_ID=your_folder_id
 
# Google OAuth
GOOGLE_CLIENT_ID=your_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your_secret
 
# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=run_openssl_rand_base64_32
 
# User Access Control
# Comma-separated emails that ALWAYS have admin access, regardless of the
# database state. This guarantees you can never lock yourself out.
SEED_ADMIN_EMAILS=you@yourcompany.com,teammate@yourcompany.com
 
# Vercel KV (required to persist the user allowlist — add via
# Vercel Dashboard -> Storage -> Create Database -> KV, then it auto-populates these)
KV_REST_API_URL=
KV_REST_API_TOKEN=
 
 